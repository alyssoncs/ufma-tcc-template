% todos os pacotes e suas configuracoes ficam neste arquivo

\ProvidesPackage{tccconfig}

\usepackage{metalogo} % Define macros \XeLaTeX e \XeTeX, pode ser removido se não usar esses logos

\usepackage{indentfirst} % Garante recuo do primeiro parágrafo em cada seção.
\usepackage{microtype} % Melhora a tipografia do documento com ajustes finos.
\usepackage{xcolor} % Permite o uso de cores no documento.
\usepackage{graphicx} % Permite a inclusão e manipulação de gráficos e imagens no documento.
\usepackage{listings} % Permite a inclusão e formatação de código-fonte no documento.
\usepackage{mathtools} % Fornece melhorias e extensões para a tipografia matemática
\usepackage{xspace} % Facilita o uso de macros personalizadas sem precisar de espaços adicionais.
\usepackage{bm} % Permite o uso de negrito em símbolos matemáticos.
\usepackage{pdfpages} % Permite a inclusão de páginas de arquivos PDF em documentos LaTeX.
\usepackage{fontspec} % Gerenciamento de fontes para XeLaTeX
\setmonofont{CascadiaCode}[
  UprightFont=*-Regular,
  BoldFont=*-Bold,
  Scale=MatchLowercase,
]
\usepackage{siunitx} % Fornece uma forma consistente de apresentar unidades e números.
\usepackage[
	strict=true,
	style=brazilian,
]{csquotes}
\usepackage{hyperref} % Adiciona links clicáveis para referências, notas de rodapé, e URLs no documento.
\usepackage[
	style=abnt,
	backend=biber,
	pretty,
	giveninits,
	noslsn,
	backref=true,
    citecount
]{biblatex} % Citações padrão ABNT com biblatex-abnt (https://ctan.org/pkg/biblatex-abnt)
\addbibresource{bib/biblio.bib}

\xspaceaddexceptions{
	\csq@qclose@i
}

\definecolor{base-green}{rgb}{0.09,0.45,0.27}
\colorlet{color-link}{base-green}
\colorlet{color-cite}{base-green}
\colorlet{color-url}{base-green}

\makeatletter
\hypersetup{
	colorlinks=true, % links com cor
	linkcolor=color-link, % cor dos links internos
	citecolor=color-cite, % cor das citacoes
	urlcolor=color-url, % cor das url externas
	bookmarksnumbered=true,
	bookmarksdepth,
	pdftitle={\@title}, % metadado do pdf, titulo
	pdfauthor={\@author}, % metadado do pdf, autor
}
\makeatother

% Configuração para numeração sequencial
\AtBeginDocument{
    \counterwithout{lstlisting}{chapter}
}

\definecolor{commentcolor}{rgb}{0.54,0.54,0.54}
\definecolor{numberlinecolor}{rgb}{0.68,0.70,0.76}
\definecolor{stringcolor}{rgb}{0.02,0.49,0.09}
\definecolor{backgroundcolor}{rgb}{0.93,0.95,0.92}
\definecolor{identifiercolor}{rgb}{0,0.2,0.70}

\lstdefinestyle{baseStyle}{
	backgroundcolor=\color{white},
	commentstyle=\color{commentcolor},
	numberstyle=\scriptsize\color{numberlinecolor},
	keywordstyle=\bfseries\color{identifiercolor},
	stringstyle=\color{stringcolor},
	basicstyle=\small\ttfamily,
	rulecolor=\color{numberlinecolor},
	captionpos=b,
	frame=single,
	showstringspaces=false,
	breaklines=true,
	tabsize=4,
	numbers=left,
	escapeinside={(*@}{@*)},
	numbersep=10pt,
}

\lstdefinestyle{javaStyle}{
	style=baseStyle,
	language=java,
	morekeywords={String},
}

\lstdefinestyle{latexStyle}{
	style=baseStyle,
	language=[LaTeX]TeX,
	morekeywords={
		lstinputlisting,
		chapter,
		subsection,
        textcite
	},
}

\setlength{\parindent}{1.3cm} % paragraph identation
\setlength{\parskip}{0.2cm} % space between paragraph
\renewcommand{\lstlistingname}{Código}

