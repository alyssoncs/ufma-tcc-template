% Configuração de fontes para XeLaTeX: fontspec + fonte monoespaçada Cascadia Code.
% A fonte é resolvida por arquivo (Extension=.otf), então o fontspec/kpathsea a
% encontra no texmf em qualquer SO, sem precisar instalá-la no sistema.

\RequirePackage{fontspec} % Gerenciamento de fontes para XeLaTeX
\setmonofont{CascadiaCode}[
  Extension=.otf,
  UprightFont=*-Regular,
  BoldFont=*-Bold,
  Scale=MatchLowercase,
]

\endinput
