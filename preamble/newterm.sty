% Define o comando \newterm, usado para criar termos com escrita/formatação
% consistente ao longo do documento. Este arquivo é autossuficiente: não depende
% de nenhuma outra parte do template, apenas do kernel do LaTeX/expl3.

\ProvidesPackage{preamble/newterm}

% Define um novo termo com o comando \newterm
% \newterm{<nome do comando>}{<singular>}
% \newterm{<nome do comando>}{<singular>}[plural=..., cap=..., capplural=...]
% \newterm*{<nome do comando>}{<singular>}[...]   % bloqueia capitalização
%
% Cria um comando <nome do comando> que, no corpo do documento, suporta dois
% modificadores:
%   *    -> versão capitalizada (ex.: \termo*)
%   [s]  -> versão no plural    (ex.: \termo[s], \termo*[s])
%
% Chaves opcionais (espaços extras são removidos automaticamente):
%   plural    -> texto no plural (minúsculo)
%   cap       -> texto capitalizado (singular)
%   capplural -> texto capitalizado no plural
% Se cap/capplural forem omitidos, a capitalização é feita automaticamente sobre
% o singular/plural com \text_titlecase_first:n (sem adivinhar sufixos). Se forem
% fornecidos, têm prioridade absoluta e o texto literal é impresso como está.
%
% Exemplos:
% \newterm{\iot}{IoT}
% \newterm{\vetor}{vetor}[plural=vetores]
% \newterm*{\hardware}{hardware}[plural=hardwares]  % \hardware* é proibido
%
% Validação estrita (interrompe a build):
%   - \termo[s] ou \termo*[s] sem plural/capplural definidos => no-plural-defined
%   - usar * em termo criado com \newterm* => capitalization-blocked
%   - definir \newterm* com cap ou capplural (na definição) => cap-keys-on-blocked
%   - modificador de plural diferente do literal 's' (ex.: [S], [es], []) =>
%     invalid-plural-modifier
%
% Atenção: como qualquer comando LaTeX, um termo seguido de espaço e mais
% texto engole esse espaço (ex.: "\iot é" vira "IoTé"). Nesses casos, use a
% forma explícita "\iot{} é". Antes de uma pontuação (.,;:) não é necessário.
% Pelo mesmo motivo, um termo seguido de "[" literal no texto seria confundido
% com o modificador de plural; nesse caso use "\termo{}[".
\ExplSyntaxOn

\msg_new:nnn { newterm } { no-plural-defined }
{ Term~'\c_backslash_str #1'~has~no~plural~defined~(key~'plural'~or~'capplural'~missing). }
\msg_new:nnn { newterm } { capitalization-blocked }
{ Term~'\c_backslash_str #1'~was~defined~with~\c_backslash_str newterm*~and~does~not~allow~capitalization~(*). }
\msg_new:nnn { newterm } { cap-keys-on-blocked }
{ Term~'\c_backslash_str #1'~was~defined~with~\c_backslash_str newterm*~(capitalization~blocked),~so~it~cannot~take~the~'cap'~or~'capplural'~keys. }
\msg_new:nnn { newterm } { invalid-plural-modifier }
{ Term~'\c_backslash_str #1'~got~an~invalid~plural~modifier~'#2';~only~the~literal~'[s]'~is~accepted. }

% --- Per-term storage (filled by the keys below, read at definition time) ---
% Flags recording which optional keys were supplied for the current term, plus
% the token lists holding their values.
\bool_new:N \l__newterm_has_plural_bool
\bool_new:N \l__newterm_has_cap_bool
\bool_new:N \l__newterm_has_capplural_bool
\bool_new:N \l__newterm_caps_blocked_bool
\tl_new:N \l__newterm_plural_tl
\tl_new:N \l__newterm_cap_tl
\tl_new:N \l__newterm_capplural_tl

% Each key stores its value and raises the matching "has" flag, so the
% constructor can tell a missing key apart from an empty one.
\keys_define:nn { newterm }
{
  plural    .code:n = { \tl_set:Nn \l__newterm_plural_tl    {#1} \bool_set_true:N \l__newterm_has_plural_bool    } ,
  cap       .code:n = { \tl_set:Nn \l__newterm_cap_tl       {#1} \bool_set_true:N \l__newterm_has_cap_bool       } ,
  capplural .code:n = { \tl_set:Nn \l__newterm_capplural_tl {#1} \bool_set_true:N \l__newterm_has_capplural_bool } ,
}

% Guard: the plural modifier must be exactly the literal 's'. Any other content
% ([], [S], [es], spaces, ...) aborts the build. Only called when the optional
% argument is present. #1 term name  #2 modifier content typed in the text.
\cs_new_protected:Npn \__newterm_check_plural_modifier:nn #1#2
{
  \str_if_eq:nnF {#2} { s }
  { \msg_critical:nnnn { newterm } { invalid-plural-modifier } {#1} {#2} }
}

% Use-time renderer. Defined with xparse (not a pure expl3 function), so it
% takes no ':signature' in its name. The arg spec below is what matters: six
% mandatory args carry the term data frozen at definition time, then the
% trailing s/o pick up the * and [s] modifiers typed in the text.
% #1 name  #2 singular  #3 caps-blocked(0/1)  #4 plural|-NoValue-
% #5 cap|-NoValue-  #6 capplural|-NoValue-
% #7 star (capitalize)  #8 optional arg present => plural
\NewDocumentCommand{\__newterm_use}{ m m m m m m s o }
{
  % Any optional argument must be exactly '[s]', regardless of variant.
  \IfValueT {#8} { \__newterm_check_plural_modifier:nn {#1} {#8} }
  \IfBooleanTF {#7}
  % --- Capitalized variant requested (\macro* / \macro*[s]) ---
  {
    \str_if_eq:nnTF {#3} { 1 }
    % Term was defined with \newterm*: any capitalization is forbidden.
    { \msg_critical:nnn { newterm } { capitalization-blocked } {#1} }
    {
      \IfValueTF {#8}
      % Capitalized plural (\macro*[s]).
      {
        \tl_if_novalue:nTF {#6}
        % No explicit capplural: fall back to title-casing the plural...
        {
          \tl_if_novalue:nTF {#4}
          % ...but only if a plural exists; otherwise there is nothing to cap.
          { \msg_critical:nnn { newterm } { no-plural-defined } {#1} }
          { \text_titlecase_first:n {#4} }
        }
        % Explicit capplural wins and is printed verbatim.
        { #6 }
      }
      % Capitalized singular (\macro*).
      {
        \tl_if_novalue:nTF {#5}
        % No explicit cap: title-case the singular automatically.
        { \text_titlecase_first:n {#2} }
        % Explicit cap wins and is printed verbatim.
        { #5 }
      }
    }
  }
  % --- Lowercase variant (\macro / \macro[s]) ---
  {
    \IfValueTF {#8}
    % Lowercase plural (\macro[s]).
    {
      \tl_if_novalue:nTF {#4}
      % No plural key defined: this term simply has no plural.
      { \msg_critical:nnn { newterm } { no-plural-defined } {#1} }
      { #4 }
    }
    % Plain singular (\macro).
    { #2 }
  }
}

% Constructor: \newterm*{\macro}{singular}[keys]. The star blocks capitalization.
% #1 star (blocks capitalization)  #2 macro name  #3 singular  #4 [keys]|-NoValue-
\NewDocumentCommand{\newterm}{ s m m o }
{
  % Reset shared scratch state before parsing this term's keys.
  \bool_set_false:N \l__newterm_has_plural_bool
  \bool_set_false:N \l__newterm_has_cap_bool
  \bool_set_false:N \l__newterm_has_capplural_bool
  \tl_clear:N \l__newterm_plural_tl
  \tl_clear:N \l__newterm_cap_tl
  \tl_clear:N \l__newterm_capplural_tl
  \IfValueT {#4} { \keys_set:nn { newterm } {#4} }
  % Record whether the star (capitalization-blocked) variant was used.
  \IfBooleanTF {#1}
  { \bool_set_true:N \l__newterm_caps_blocked_bool }
  { \bool_set_false:N \l__newterm_caps_blocked_bool }
  % Definition-time check: a caps-blocked term cannot carry cap/capplural keys.
  \bool_lazy_and:nnT
  { \l__newterm_caps_blocked_bool }
  { \bool_lazy_or_p:nn { \l__newterm_has_cap_bool } { \l__newterm_has_capplural_bool } }
  { \msg_critical:nnx { newterm } { cap-keys-on-blocked } { \cs_to_str:N #2 } }
  % Freeze this term's data into the generated macro: \use:e expands the flags
  % and values now so the macro body carries them, independent of the shared
  % scratch variables (which the next \newterm will overwrite). Missing keys
  % become \c_novalue_tl so the renderer can detect them.
  \use:e
  {
    \cs_new_protected:Npn \exp_not:N #2
    {
      \exp_not:N \__newterm_use
      { \cs_to_str:N #2 }
      { \exp_not:n {#3} }
      { \bool_if:NTF \l__newterm_caps_blocked_bool { 1 } { 0 } }
      { \bool_if:NTF \l__newterm_has_plural_bool    { \exp_not:V \l__newterm_plural_tl    } { \c_novalue_tl } }
      { \bool_if:NTF \l__newterm_has_cap_bool       { \exp_not:V \l__newterm_cap_tl       } { \c_novalue_tl } }
      { \bool_if:NTF \l__newterm_has_capplural_bool { \exp_not:V \l__newterm_capplural_tl } { \c_novalue_tl } }
    }
  }
}
\ExplSyntaxOff

\endinput
